{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {}
  },
  "include": [
    "src/**/*.ts",
    "generated/**/*.ts",
    "../../app/lib/rule-engine/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
